---
import Analytics from "@vercel/analytics/astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
}

const { title, description, image, canonical } = Astro.props;
const defaultDescription =
  "A performance engineering framework by Den Odell with practical guidance for building fast, responsive systems. Learn how to design for speed across web, mobile, backend, and desktop.";
const metaDescription = description || defaultDescription;

const siteUrl = "https://fastbydefault.com";
const canonicalUrl =
  canonical ||
  new URL(Astro.url.pathname, siteUrl).toString().replace(/\/$/, "");
const ogImage = image || `${siteUrl}/og-image.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={metaDescription} />
    <meta name="author" content="Den Odell" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#1c1917" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Fast by Default" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:creator" content="@denodell" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Lora:ital,wght@0,400;0,600;1,400&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Privacy-friendly analytics by Plausible -->
    <script async src="https://plausible.io/js/pa-DaVyYJLEfT9p_2vefAePa.js"
    ></script>
    <script>
      (window.plausible =
        window.plausible ||
        function () {
          (plausible.q = plausible.q || []).push(arguments);
        }),
        (plausible.init =
          plausible.init ||
          function (i) {
            plausible.o = i || {};
          });
      plausible.init();
    </script>
  </head>
  <body class="font-serif">
    <!-- Book Promotion -->
    <section
      class="bg-stone-900 dark:bg-stone-950 border-b-4 border-double border-stone-900 dark:border-stone-100"
    >
      <div
        class="max-w-5xl mx-auto px-6 py-5 flex flex-col sm:flex-row items-center gap-5 sm:gap-8"
      >
        <a
          href="https://www.manning.com/books/performance-engineering-in-practice"
          class="shrink-0"
        >
          <img
            src="https://images.manning.com/264/352/resize/book/e/271edd0-1a47-492d-bdc9-66f3c7ab785b/Odell-MEAP-HI.png"
            alt="Performance Engineering In Practice book cover"
            width="100"
            height="133"
            class="border border-stone-700"
          />
        </a>
        <div class="text-center sm:text-left flex-1">
          <p
            class="font-sans text-xs tracking-[0.2em] uppercase text-stone-400 dark:text-stone-500 mb-1"
          >
            New Book &mdash; MEAP Early Access
          </p>
          <h2
            class="font-display text-2xl font-bold text-stone-100 tracking-tight mb-1"
          >
            Performance Engineering In Practice
          </h2>
          <p class="text-stone-300 dark:text-stone-400 text-sm leading-relaxed">
            The book that shows you how to put Fast by Default into action
            across web, mobile, and desktop applications.
          </p>
        </div>
        <a
          href="https://www.manning.com/books/performance-engineering-in-practice"
          class="shrink-0 px-6 py-2.5 bg-stone-100 text-stone-900 font-sans font-semibold text-sm tracking-wide uppercase hover:bg-white transition-colors"
        >
          Get the Book
        </a>
      </div>
    </section>

    <slot />

    <!-- Newsletter Section -->
    <section
      class="bg-stone-100 dark:bg-stone-800 py-20 border-t-2 border-b-2 border-stone-900 dark:border-stone-100"
    >
      <div class="max-w-2xl mx-auto px-6 text-center">
        <h2
          class="font-display text-4xl sm:text-5xl font-bold text-stone-900 dark:text-stone-100 mb-4"
        >
          Newsletter
        </h2>
        <p
          class="text-lg text-stone-600 dark:text-stone-300 leading-relaxed max-w-xl mx-auto mb-10"
        >
          A monthly email from Den Odell with behind-the-scenes thinking on
          performance engineering, updates on Fast by Default, and more.
        </p>

        <form
          action="https://buttondown.com/api/emails/embed-subscribe/denodell"
          method="post"
          class="embeddable-buttondown-form max-w-md mx-auto"
        >
          <div class="flex flex-col sm:flex-row gap-3">
            <div class="flex-1">
              <label for="bd-email" class="sr-only">Enter your email</label>
              <input
                type="email"
                name="email"
                id="bd-email"
                placeholder="your@email.com"
                required
                class="w-full px-4 py-3 border-2 border-stone-900 dark:border-stone-100 bg-white dark:bg-stone-900 text-stone-900 dark:text-stone-100 font-sans text-base focus:outline-none focus:ring-2 focus:ring-stone-700 dark:focus:ring-stone-300 placeholder-stone-400 dark:placeholder-stone-500"
              />
            </div>
            <button
              type="submit"
              class="px-8 py-3 bg-stone-900 dark:bg-stone-100 text-white dark:text-stone-900 font-sans font-semibold text-base tracking-wide uppercase hover:bg-stone-700 dark:hover:bg-stone-300 transition-colors border-2 border-stone-900 dark:border-stone-100"
            >
              Subscribe
            </button>
          </div>
        </form>

        <p class="mt-4 text-sm font-sans text-stone-600 dark:text-stone-300">
          One email per month, no spam.
        </p>
      </div>
    </section>

    <!-- Footer -->
    <footer
      class="bg-stone-900 dark:bg-stone-950 text-stone-300 dark:text-stone-400 py-12 border-t-4 border-double border-stone-900 dark:border-stone-100"
    >
      <div class="max-w-6xl mx-auto px-6 text-center">
        <div class="inline-block py-2">
          <p
            class="font-display text-2xl font-bold text-white dark:text-stone-100"
          >
            Fast by Default
          </p>
        </div>

        <p
          class="mb-8 font-sans text-xs tracking-wider uppercase text-stone-400 dark:text-stone-400"
        >
          &copy; {new Date().getFullYear()}&nbsp;<a
            href="https://denodell.com?utm_source=fastbydefault&utm_medium=website&utm_campaign=footer"
            class="hover:text-stone-300 dark:hover:text-stone-400 transition-colors"
            >Den Odell</a
          >
        </p>

        <h1 class="text-sm font-bold text-stone-100 mb-1">
          Projects by Den Odell
        </h1>
        <p class="text-sm">
          <a
            href="https://denodell.com?utm_source=fastbydefault&utm_medium=website&utm_campaign=footer_projects"
            class="text-stone-300 hover:text-stone-100">DenOdell.com</a
          >
          <span class="mx-2 text-stone-500">•</span>
          <a
            href="https://fastbydefault.com?utm_source=fastbydefault&utm_medium=website&utm_campaign=footer_projects"
            class="text-stone-300 hover:text-stone-100">Fast by Default</a
          >
          <span class="mx-2 text-stone-500">•</span>
          <a
            href="https://byteshrink.dev?utm_source=fastbydefault&utm_medium=website&utm_campaign=footer_projects"
            class="text-stone-300 hover:text-stone-100">Byteshrink AI</a
          >
        </p>
      </div>
    </footer>
    <Analytics />
  </body>
</html>
